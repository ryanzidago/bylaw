#!/usr/bin/env bash
set -euo pipefail

hook_name="${1:-git-hook}"

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

branch="$(git symbolic-ref --quiet --short HEAD || true)"

case "$hook_name" in
  pre-commit)
    if [ "$branch" = "main" ]; then
      echo "ERROR: Direct commits to main are not allowed."
      echo "Please use a linked worktree under .worktrees/ instead."
      exit 1
    fi
    ;;

  pre-push)
    if [ "$branch" = "main" ]; then
      echo "ERROR: Direct pushes from main are not allowed."
      echo "Please use a linked worktree under .worktrees/ instead."
      exit 1
    fi
    ;;
esac

output=$(mix qa 2>&1) || {
  echo "$output"
  exit 1
}

echo "qa passed"
